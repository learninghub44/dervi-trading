# ─── Deriv OAuth / App credentials ───────────────────────────────────────────
# Register your app at https://app.deriv.com/account/api-token
# and https://developers.binary.com/applications/ to get these values.

# OAuth client ID from Deriv app registration
DERIV_AUTH_CLIENT_ID=

# OAuth client secret (if Deriv issues one; leave blank for public clients)
DERIV_AUTH_CLIENT_SECRET=

# Must exactly match what you registered as the redirect URI
DERIV_AUTH_REDIRECT_URI=http://localhost:5173/callback

# Your Deriv App ID (integer) — used in Deriv-App-ID header
DERIV_APP_ID=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# These VITE_ vars are inlined at build time into the browser bundle.

VITE_DERIV_AUTH_CLIENT_ID=
VITE_DERIV_AUTH_REDIRECT_URI=http://localhost:5173/callback

# In dev, leave blank (Vite proxy handles it). In prod, set to your domain.
VITE_BACKEND_URL=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Dev only: Vite origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
