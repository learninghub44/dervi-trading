# ── Deriv credentials ──────────────────────────────────────────────────────
DERIV_APP_ID=YOUR_APP_ID
DERIV_AUTH_CLIENT_ID=YOUR_CLIENT_ID
DERIV_AUTH_CLIENT_SECRET=
# In production: https://YOUR_APP.up.railway.app/callback
DERIV_AUTH_REDIRECT_URI=http://localhost:5173/callback

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (dev only — in prod these are empty, same origin) ─────────────
VITE_DERIV_AUTH_CLIENT_ID=YOUR_CLIENT_ID
VITE_DERIV_AUTH_REDIRECT_URI=http://localhost:5173/callback
VITE_BACKEND_URL=
